__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_13.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="13">
  <P Name="name">RNP AR Approach Guidance/L1GuidanceVersion1/guidanceL1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">13</P>
  <P Name="ssIdHighWaterMark">11</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">1</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">L1_Guidance_Logic</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">13</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [L1, eta] = L1_Guidance_Logic(eta1, YZ, Lfw, R_turn, turnDir, legType)
    % ---------------------------------------------------------------------
    % 固翼无人机 L1 非线性制导律 (完美适配 RNPAR 飞行计划解析逻辑)
    % ---------------------------------------------------------------------

    % 1. 统一计算动态 L1 距离
    L1 = sqrt(YZ^2 + Lfw^2);
    
    if legType == 0
        % =================================================================
        % 【直线段逻辑】 
        % 你的示波器显示直线段已完美收敛，这部分保持不变！
        % =================================================================
        eta = atan(YZ / Lfw) - eta1;
        
    else
        % =================================================================
        % 【圆弧段逻辑】
        % =================================================================
        
        % ★ 终极修复：完美对接你的 Para_XTK 公式！
        % 因为你的代码是 Para_XTK = turnDir * (d - R_turn)
        % 所以绝对距离 d 必须通过乘以 turnDir 还原，解决左转正反馈发散问题
        d = R_turn + YZ * turnDir; 
        
        % 防止飞机刚好飞越圆心导致除零溢出奇点
        if d &lt; 0.1
            d = 0.1;
        end
        
        % 利用余弦定理计算夹角 alpha
        cos_alpha = (d^2 + L1^2 - R_turn^2) / (2 * d * L1);
        cos_alpha = max(min(cos_alpha, 1), -1); % 防复数安全限幅
        sin_alpha = sqrt(1 - cos_alpha^2);
        
        % 计算速度矢量与圆心矢量的夹角 beta
        beta = -eta1 + (pi/2) * turnDir;
        
        % 纯代数几何拼装 L1 视线前置角
        sin_eta = sin(beta) * cos_alpha - turnDir * cos(beta) * sin_alpha;
        
        % 安全限幅与还原
        sin_eta = max(min(sin_eta, 1), -1);
        eta = asin(sin_eta);
    end
    
    % 防溢出归一化 (Wrap to Pi)，防止角度出现 359度 - 1度 = 358度 的暴力满舵
    eta = mod(eta + pi, 2*pi) - pi;
    
end</P>
      </eml>
    </state>
