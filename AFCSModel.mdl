<?xml version="1.0" encoding="utf-8"?>
<chart id="26">
  <P Name="name">RNP AR Approach Guidance/L1GuidanceVersion1/guidanceL2Plus</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">26</P>
  <P Name="ssIdHighWaterMark">11</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">2</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">L2_Guidance_Plus</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">26</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [L1_out, eta] = L2_Guidance_Plus(eta1, YZ, L2_in, R_turn, turnDir, legType)
    % ---------------------------------------------------------------------
    % 固翼无人机 L2+ 非线性制导律 (引入大误差虚拟瞄准点)
    % ---------------------------------------------------------------------
    
    % L2+ 算法大横向误差虚拟瞄准点参数
    gamma_max = 45 * pi / 180; % 最大切入角限制 (通常为 45 度)
    M_star = 2.0;              % 顺延距离乘子系数 M*
    
    % 输入的 Lfw 在 L2+ 架构中即为设定的名义前视距离 |L2|
    L2_nom = L2_in; 

    if legType == 0
        % =================================================================
        % 【直线段逻辑 - L2+ 虚拟瞄准点】
        % =================================================================
        if abs(YZ) &lt;= L2_nom
            % 横向误差小于名义前视距离：经典 L1 几何精确求交
            x_aim = sqrt(L2_nom^2 - YZ^2);
            L1_out = L2_nom;
        else
            % 横向误差大于名义前视距离：激活 L2+ 虚拟瞄准点
            x_max_angle = abs(YZ) / tan(gamma_max);
            x_max_dist  = M_star * L2_nom;
            
            % 取两者中较小的一个作为直线上前向顺延距离
            x_aim = min(x_max_angle, x_max_dist);
            
            % 重新计算实际有效的前视距离斜边
            L1_out = sqrt(YZ^2 + x_aim^2);
        end
        
        % 计算视线角 eta
        % atan2 可自动处理全部象限，更为稳健
        eta = atan2(YZ, x_aim) - eta1;
        
    else
        % =================================================================
        % 【圆弧段逻辑 - 引入 L2+ 等效距离扩展】
        % =================================================================
        d = R_turn + YZ * turnDir; 
        
        if d &lt; 0.1
            d = 0.1;
        end
        
        % 采用与直线段相同的约束逻辑动态计算圆弧上的有效 L1 距离
        % 以防止远距离切入圆弧时产生数学奇点
        if abs(YZ) &lt;= L2_nom
            L1_eff = L2_nom;
        else
            x_max_angle = abs(YZ) / tan(gamma_max);
            x_max_dist  = M_star * L2_nom;
            x_aim = min(x_max_angle, x_max_dist);
            L1_eff = sqrt(YZ^2 + x_aim^2);
        end
        
        L1_out = L1_eff;
        
        % 余弦定理求交（带有防复数限幅保护）
        cos_alpha = (d^2 + L1_eff^2 - R_turn^2) / (2 * d * L1_eff);
        cos_alpha = max(min(cos_alpha, 1), -1); 
        sin_alpha = sqrt(1 - cos_alpha^2);
        
        beta = -eta1 + (pi/2) * turnDir;
        
        sin_eta = sin(beta) * cos_alpha - turnDir * cos(beta) * sin_alpha;
        
        sin_eta = max(min(sin_eta, 1), -1);
        eta = asin(sin_eta);
    end
    
    % 防溢出归一化处理 (Wrap to Pi)
    eta = mod(eta + pi, 2*pi) - pi;
    
end</P>
      </eml>
    </state>
    <data SSID="4" name="eta1">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="L1_out">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
